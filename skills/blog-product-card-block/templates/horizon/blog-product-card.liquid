{%- doc -%}
  Theme block: blog product card.

  This block doesn't render the product card directly into the page.
  Instead, the `_blog-post-content` block scans `section.blocks` for
  instances of this block and replaces `[product-card:<placeholder_id>]`
  tokens inside `article.content` with the rendered card HTML.

  In Theme Editor (design mode), a labeled marker is shown so merchants
  can locate, click and configure the block. On the live storefront,
  the block renders nothing on its own.
{%- enddoc -%}

{%- if request.design_mode -%}
  {{ 'blog-product-card.css' | asset_url | stylesheet_tag }}

  <div class="bpc-block-marker" {{ block.shopify_attributes }}>
    Blog Product Card
    {%- if block.settings.placeholder_id != blank -%}
      &nbsp;占位符:&nbsp;<code>[product-card:{{ block.settings.placeholder_id }}]</code>
    {%- else -%}
      &nbsp;<em>请填写"占位符 ID"，并在文章正文中插入对应占位符</em>
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Blog Product Card",
  "settings": [
    {
      "type": "paragraph",
      "content": "在文章正文中插入占位符 [product-card:你填的ID]，发布后会被替换成产品卡。每个 block 的 ID 必须唯一。"
    },
    {
      "type": "text",
      "id": "placeholder_id",
      "label": "占位符 ID",
      "info": "例如填 card-1，正文中写 [product-card:card-1]",
      "default": "card-1"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "highlights",
      "label": "Feature Highlights",
      "info": "可选，单行卖点。如：✔ 11-speed  ✔ 5.3QT  ✔ Touchscreen"
    },
    {
      "type": "text",
      "id": "learn_more_label",
      "label": "Learn More 按钮文字",
      "default": "Learn More"
    },
    {
      "type": "text",
      "id": "atc_label",
      "label": "Add to Cart 按钮文字",
      "default": "Add to Cart"
    }
  ],
  "presets": [
    {
      "name": "Blog Product Card"
    }
  ]
}
{% endschema %}
